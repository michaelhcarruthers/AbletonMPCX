OPENAI_API_KEY=sk-...

# Comma-separated tool groups to load. Leave blank to load all tools.
# Available groups: base, session, mixer, clips, devices, arrangement, performance, diagnostics, templates, observer
# Example (recommended for Claude): AMCPX_TOOL_GROUPS=base,session,mixer,clips,arrangement,devices
AMCPX_TOOL_GROUPS=

# Your ngrok hostname (without https://) for ChatGPT Desktop MCP access via ngrok.
# Update this each session when using a free ngrok URL.
# Example: NGROK_HOST=tribesman-plop-unlovely.ngrok-free.dev
NGROK_HOST=
